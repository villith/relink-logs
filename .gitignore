*.dll
*.gbfr
**/target/

# Generated build artifact (built by scripts/build.ps1; also matched by *.dll above)
src-tauri/hook.dll

# Local reference data, not part of the app
docs/damage-calculators/

# Superpowers specs/plans are local working notes — never commit them
docs/superpowers/

# CI-only Tauri config overlay (carries bundle.windows.signCommand), written
# by .github/workflows/release.yaml at build time — never committed
.tauri-release-config.json

# Tauri updater signing keys — NEVER commit the private key
.tauri/
*.key
*.key.pub
/.worktrees
